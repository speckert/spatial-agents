# Spatial Agents — Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# aisstream.io API key (free at https://aisstream.io)
SPATIAL_AGENTS_AIS_KEY=

# OpenSky Network OAuth2 credentials (free at https://opensky-network.org)
# Create an API client in your account settings to get these
SPATIAL_AGENTS_ADSB_CLIENT_ID=
SPATIAL_AGENTS_ADSB_CLIENT_SECRET=

# Deployment mode: local_mac or cloud
# SPATIAL_AGENTS_MODE=local_mac

# Server port
# SPATIAL_AGENTS_PORT=8012

# Data directory (defaults to ./data for local_mac, /data for cloud)
# SPATIAL_AGENTS_DATA_DIR=

# Tile output directory (defaults to {data_dir}/tiles/h3)
# SPATIAL_AGENTS_TILE_DIR=

# Cloud mode only — S3 configuration
# SPATIAL_AGENTS_S3_BUCKET=
# SPATIAL_AGENTS_S3_REGION=us-west-2
